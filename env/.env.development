### 편의를 위해 가능한 디폴트값으로 설정 ###
### app/core/config.py 전달 ###
# TZ=Asia/Seoul
# JWT관련
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24 # 24시간
JWT_REFRESH_TOKEN_EXPIRE_DAYS=28 # 4주 28일

# SQL 관련
DB_NAME=esg_db
DB_USER=root
DB_PWD=1111
DB_PORT=3306
DB_IP=mysql80
# DB_IP=127.0.0.1

# Redis관련
REDIS_HOST=redis7alpine
# REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# AWS 도커 연결
MYSQL_ROOT_PASSWORD=1111
MYSQL_DATABASE=esg_db

# Claude LLM모델, extended thinking 적용할 모델
# LLM_MODEL=claude-haiku-4-5-20251001
# RAG_LLM_MODEL=claude-sonnet-4-5-20250929
LLM_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
RAG_LLM_MODEL=us.anthropic.claude-sonnet-4-6

# RAG - ChromaDB (로컬 persistent), Ollama (로컬)
CHROMA_NAME=chroma_db
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_EMBED_MODEL=bge-m3